.pio/
/sdkconfig
/sdkconfig.*
!/sdkconfig.defaults
# tracked per-target overrides (e.g. sdkconfig.defaults.esp32 → PSRAM for the CAM)
!/sdkconfig.defaults.*
managed_components/
dependencies.lock
.superpowers/

# Real venue Wi-Fi credentials for the hub role's STA uplink — copy
# src/wifi_creds.example.h → src/wifi_creds.h and fill it in. NEVER commit the real one.
src/wifi_creds.h

# Generated by tools/embed_web.py (pre-build) from web/ — the hub role's
# embedded pages as byte arrays (dashboard ~2.4 MB as C text; shell tiny).
src/dashboard_html.c
src/ide_shell_html.c

