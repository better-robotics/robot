.pio/
/sdkconfig
/sdkconfig.*
!/sdkconfig.defaults
# tracked per-target overrides (e.g. sdkconfig.defaults.esp32 → PSRAM for the CAM)
!/sdkconfig.defaults.*
managed_components/
dependencies.lock
.superpowers/

# Real venue Wi-Fi credentials for the hub role's STA uplink — copy
# src/wifi_creds.example.h → src/wifi_creds.h and fill it in. NEVER commit the real one.
src/wifi_creds.h

# Generated by tools/embed_dashboard.py (pre-build) from web/dashboard.html — the
# hub role's embedded dashboard as a byte array. ~2.4 MB; regenerated every build.
src/dashboard_html.c

# Vendored by tools/sync-ide.sh from better-robotics/ide's ide-esp32 release
# asset (pinned tag in the script), and its generated embed (tools/embed_ide.py).
web/ide/
src/ide_bundle.c
